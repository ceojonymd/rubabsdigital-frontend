# Rubabs Digital example environment
# Copy this file to .env.local on the server and fill in real values there.
# Do not commit real secrets.

# Contact / mail
SMTP_HOST="replace-me"
SMTP_PORT="587"
SMTP_USER="replace-me"
SMTP_PASS="replace-me"

# Telegram alerts
TELEGRAM_BOT_TOKEN="replace-me"
TELEGRAM_CHAT_ID="replace-me"

# Contact intake webhook
N8N_CONTACT_WEBHOOK_URL="https://example.com/webhook/contact"
N8N_CONTACT_WEBHOOK_TOKEN="replace-me"

# Digest and alert webhooks
N8N_OPS_DIGEST_WEBHOOK_URL="https://example.com/webhook/ops-digest"
N8N_OPS_DIGEST_WEBHOOK_TOKEN="replace-me"
N8N_EXEC_SUMMARY_WEBHOOK_URL="https://example.com/webhook/executive-summary"
N8N_EXEC_SUMMARY_WEBHOOK_TOKEN="replace-me"
N8N_CRITICAL_ALERT_WEBHOOK_URL="https://example.com/webhook/critical-alert"
N8N_CRITICAL_ALERT_WEBHOOK_TOKEN="replace-me"

# Machine-to-machine auth
RD_M2M_SIGNING_KEY_SLOT="default"
RD_M2M_SIGNING_SECRET="replace-me"

# Public preference links
RD_PREFERENCE_TOKEN_SECRET="replace-me"
RD_PREFERENCE_TOKEN_MAX_AGE_SECONDS="1209600"

# Retention
RD_AUDIT_RETENTION_DAYS="365"
RD_DIGEST_RETENTION_DAYS="180"
RD_INCIDENT_RETENTION_DAYS="365"
